function nbfind(){
find . -name '*.ipynb' | while read -r file; do  jq -r '.cells[].source[]?' "$file" | grep --color=always -H "$1" | sed "s|^|$file: |"; done | less -R
}

xc() {
    if command -v wl-copy >/dev/null 2>&1 && [ -n "$WAYLAND_DISPLAY" ]; then
        wl-copy < "$1"
    elif command -v xsel >/dev/null 2>&1; then
        xsel --clipboard --input < "$1"
    else
        echo "No clipboard utility found" >&2
        return 1
    fi
}


