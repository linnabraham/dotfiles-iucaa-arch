# [Created by ķtask 3.4.1 8/8/2025 16:30:11]
data.location=/home/linn/.task
news.version=3.4.1

# To use the default location of the XDG directories,
# move this configuration file from ~/.taskrc to ~/.config/task/taskrc and update location config as follows:

#data.location=~/.local/share/task
#hooks.location=~/.config/task/hooks

# Color theme (uncomment one to use)
#include light-16.theme
#include light-256.theme
#include bubblegum-256.theme
#include dark-16.theme
#include dark-256.theme
#include dark-red-256.theme
#include dark-green-256.theme
#include dark-blue-256.theme
#include dark-violets-256.theme
#include dark-yellow-green.theme
#include dark-gray-256.theme
#include dark-gray-blue-256.theme
#include solarized-dark-256.theme
#include solarized-light-256.theme
#include no-color.theme
uda.priority.values=H,M,,L
urgency.uda.priority.L.coefficient=-1.8
urgency.uda.priority..coefficient=1.8
report.next.columns=id,start.age,entry.age,depends,priority,project,tags,recur,scheduled.countdown,due.relative,until.remaining,description.count,urgency
report.next.filter=status:pending -WAITING -archive -project limit:30
report.shownext.columns=id,start.age,entry.age,depends,recur,scheduled.countdown,due.relative,until.remaining,description.count,tags
report.shownext.filter=status:pending -WAITING -archive -project limit:30
report.shownext.sort=urgency-
urgency.user.tag.urgent.coefficient=2
urgency.user.tag.wontdo.coefficient=-5
urgency.user.tag.idea.coefficient=-4
urgency.user.tag.someday.coefficient=-1
urgency.user.tag.maybe.coefficient=-4
urgency.user.tag.dashboard.coefficient=-5
urgency.user.tag.wild.coefficient=-2
urgency.user.project.work.coefficient=2
urgency.user.project.house.coefficient=-1
urgency.user.project.fun.coefficient=-2
urgency.user.project.sidequest.coefficient=-3
urgency.project.coefficient=0.0
urgency.tags.coefficient=0.0
urgency.blocking.coefficient=1.0
context.house.read=+@house or proj:house
context.house.write=+@house
context.work.read=-maybe -someday -@outside -@laptop -@phone -@house -linux -project and proj:work or +urgent or +career or +@office
report.all.columns=id,status.short,uuid.short,start.active,entry.age,end.age,depends.indicator,priority,project.parent,tags,recur.indicator,wait.remaining,scheduled.remaining,due,until.remaining,description
#alias.house=status:pending and (proj:house or +@house)
#alias.shopping=status:pending and (proj:personal.shopping or proj:work.shopping or proj:house.shopping or +shopping)
#alias.shopping=status:pending and (proj:personal.shopping or proj:work.shopping or proj:house.shopping) and (proj.not:personal.shopping.ideas) and (proj.not:house.shopping.ideas)
#ķalias.personal=limit:30 status:pending and (proj:personal or ( proj.not:work and proj.not:fun and proj.not:sidequest ))
#alias.work=status:pending proj:work
#alias.solar=status:pending proj:work.solar
alias.fun=status:pending proj:fun
#alias.phone=status:pending +@phone
alias.peeps=tags:people
alias.dashboard=tag:dashboard
report.narrow.description=Narrow list of pending tasks
report.narrow.columns=id,project,description.count,tags,due.relative
report.narrow.labels=ID,Proj,Task,Tag,Due
report.narrow.filter=status:pending -archive -dashboard
report.narrow.sort=urgency-
default.command=narrow limit:40
report.recent.description=Narrow list of pending tasks
report.recent.columns=id,project,description.count,tags,due.relative
report.recent.labels=ID,Proj,Task,Tag,Due
report.recent.filter=status:pending -archive -dashboard limit:40
report.recent.sort=entry-
report.newest.columns=id,project,description.count,tags,due.relative
report.newest.labels=ID,Proj,Task,Tag,Due
