# IUCAA

# Receive options
set mbox_type = Maildir
set folder = "/home/linn/.local/share/mail/iucaa"
set spoolfile = +"INBOX"
set record = +"Sent"
set postponed = +"Drafts"
set trash = +"Trash"

mailboxes +INBOX +Sent +Drafts +Trash

# Send options
set smtp_url = smtp://daakghar.iucaa.in/
set smtp_user = "`pass show iucaa/zimbra/linn | grep '^user:' | cut -d' ' -f2- | cut -d'@' -f1`"
set smtp_pass="`pass show iucaa/zimbra/linn | head -n 1`"
set from = "`pass show iucaa/zimbra/linn | grep '^user:' | cut -d' ' -f2-`"
set real_name = 'Linn Abraham'

set attach_save_dir="~/Downloads/booksnstuff"
